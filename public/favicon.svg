<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#a855f7"/>
      <stop offset="50%" style="stop-color:#7c3aed"/>
      <stop offset="100%" style="stop-color:#6366f1"/>
    </linearGradient>
    <!-- 하트 메인 그라디언트 -->
    <linearGradient id="heartMain" x1="0%" y1="0%" x2="60%" y2="100%">
      <stop offset="0%" style="stop-color:#ff9ff3"/>
      <stop offset="50%" style="stop-color:#ff6ef7"/>
      <stop offset="100%" style="stop-color:#c44ddd"/>
    </linearGradient>
    <!-- 하이라이트 그라디언트 -->
    <linearGradient id="highlight" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#ffffff;stop-opacity:0.7"/>
      <stop offset="100%" style="stop-color:#ffffff;stop-opacity:0"/>
    </linearGradient>
    <!-- 그림자용 -->
    <filter id="shadow" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="0" dy="3" stdDeviation="4" flood-color="#6d28d9" flood-opacity="0.5"/>
    </filter>
  </defs>

  <!-- 배경 -->
  <rect x="8" y="8" width="84" height="84" rx="22" ry="22" fill="url(#bg)"/>

  <!-- 배경 글래스 광택 -->
  <rect x="8" y="8" width="84" height="42" rx="22" ry="22" fill="white" opacity="0.08"/>

  <!-- 하트 메인 (그림자 포함) -->
  <g transform="translate(50,52) scale(1.15)" filter="url(#shadow)">
    <path d="M0 18 C0 18 -22 6 -22 -7 C-22 -15 -16 -20 -9 -20 C-5 -20 -2 -18 0 -15 C2 -18 5 -20 9 -20 C16 -20 22 -15 22 -7 C22 6 0 18 0 18Z"
      fill="url(#heartMain)"/>
  </g>

  <!-- 하트 하이라이트 (상단 광택) -->
  <g transform="translate(50,52) scale(1.15)">
    <path d="M0 18 C0 18 -22 6 -22 -7 C-22 -15 -16 -20 -9 -20 C-5 -20 -2 -18 0 -15 C2 -18 5 -20 9 -20 C16 -20 22 -15 22 -7 C22 6 0 18 0 18Z"
      fill="url(#highlight)"/>
    <!-- 작은 하이라이트 점 -->
    <ellipse cx="-6" cy="-12" rx="5" ry="3.5" fill="white" opacity="0.35" transform="rotate(-20)"/>
  </g>
</svg>
